APP_ENV=local
APP_BASE_URL=https://localhost:8080

FARM_QUEST_ADMIN_AUTH_SECRET:replace-me

DATABASE_URL=jdbc:postgresql://localhost:5432/farm_quest
DATABASE_USERNAME=farm_quest
DATABASE_PASSWORD=farm_quest
DATABASE_PORT=5432

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:${QDRANT_PORT}
QDRANT_COLLECTION_NAME=knowledge-documents
QDRANT_VECTOR_SIZE=1536
QDRANT_INITIALIZE_ON_STARTUP=true

SPRING_AI_CHAT_PROVIDER=openai
SPRING_AI_EMBEDDING_PROVIDER=openai
PROXY_BASE_URL=https://your-openai-proxy.example.com
PROXY_API_KEY=replace-me
SPRING_AI_CHAT_MODEL=gpt-4o-mini
SPRING_AI_EMBEDDING_MODEL=text-embedding-3-small

VISITOR_SESSION_SECRET=replace-me

EMAIL_VERIFICATION_SECRET=replace-me
MAIL_MODE=log
MAIL_FROM=no-reply@example.com
MAIL_SUBJECT=Farm Quest 驗證碼
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_AUTH=true
MAIL_STARTTLS_ENABLED=true
MAIL_SSL_ENABLED=false

COUPON_TOKEN_SECRET=replace-me

PUBLIC_API_BASE_URL=https://localhost:8080
PUBLIC_APP_BASE_URL=https://localhost:5173

